---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import {
  siteMeta,
  researchInterests,
  heroHighlights,
  education,
  honors,
  projectCards,
  homeQuickFacts,
  homeFeatureCards
} from '../data/site';
---
<BaseLayout path="/">
  <section class="hero-section">
    <div class="container hero-grid">
      <aside class="profile-panel">
        <div class="profile-avatar" style="overflow: hidden; background: none;">
          <img src="/profile.jpg" alt="Yi-Chen Sun" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <h1>{siteMeta.title}</h1>
        <p class="profile-role">Direct-Entry Ph.D. Student • Medical AI • Computer Vision</p>
        <dl class="contact-grid">
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a></dd>
          </div>
          <div>
            <dt>Phone</dt>
            <dd>{siteMeta.phone}</dd>
          </div>
          <div>
            <dt>Location</dt>
            <dd>{siteMeta.location}</dd>
          </div>
          {siteMeta.birthdate && (
            <div>
              <dt>Date of Birth</dt>
              <dd>{siteMeta.birthdate}</dd>
            </div>
          )}
        </dl>
        <div class="button-row stack">
          <a class="button primary" href={siteMeta.cvPdf}>Download CV</a>
          <a class="button secondary" href="/contact">Contact</a>
        </div>
      </aside>

      <div class="hero-content">
        <article class="hero-card hero-intro">
          <span class="eyebrow">Research Vision</span>
          <h2>Translating fundamental medical AI into clinically resilient, real-world deployment.</h2>
          <p class="lead">
            I am a direct-entry Ph.D. student at National Yang Ming Chiao Tung University (NYCU) focused on
            <strong>Health Research</strong>. My work bridges the gap between rigorous algorithm development—such as
            DBI-MambaUNet for micro-lesion sensitivity—and the stringent demands of actual medical workflows.
          </p>
          <p>
            Rather than stopping at theoretical performance, I build end-to-end systems. My research spans contrast-free MRI analysis via knowledge distillation, hallucination-resistant structured reporting natively integrated with clinical PACS, and leading teams to scale TFDA/FDA-facing oncology systems.
          </p>
          <div class="button-row">
            <a class="button primary" href="/projects">View Clinical Systems & Research</a>
            <a class="button secondary" href="/cv">View Academic CV</a>
          </div>
        </article>

        <div class="metrics-grid">
          {heroHighlights.map((item) => (
            <article class="metric-card">
              <div class="metric-value">{item.value}</div>
              <div class="metric-label">{item.label}</div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-column-layout">
      <div>
        <SectionHeading eyebrow="Research Interests" title="Current Focus" />
        <article class="glass-card">
          <p>{researchInterests}</p>
          <div class="quick-list">
            {homeQuickFacts.map((fact) => (
              <div class="quick-item">{fact}</div>
            ))}
          </div>
        </article>
      </div>
      <div>
        <SectionHeading eyebrow="Why This Profile Stands Out" title="Selected Advantages" />
        <div class="feature-grid">
          {homeFeatureCards.map((card) => (
            <article class="feature-card accent-card">
              <h3>{card.title}</h3>
              <p>{card.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section alt-bg">
    <div class="container two-column-layout">
      <div>
        <SectionHeading eyebrow="Education" title="Academic Training" />
        <div class="stack-cards">
          {education.map((item) => (
            <article class="info-card">
              <div class="row-between gap align-start">
                <div>
                  <h3>{item.school}</h3>
                  <p class="muted-copy">{item.degree}</p>
                </div>
                <span class="pill">{item.period}</span>
              </div>
              {item.detail && <p class="subtle-text">{item.detail}</p>}
            </article>
          ))}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Selected Honors" title="Highlights" />
        <div class="info-card">
          <ul class="bullet-list compact">
            {honors.map((item) => <li set:html={item} />)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Selected Projects" title="Featured Work" intro="A curated set of the most representative projects from research, mentoring, challenge leadership, and translational AI." />
      <div class="feature-grid two-cols">
        {projectCards.slice(0, 8).map((project) => (
          <article class="project-card project-card-rich">
            <div class="project-meta-stack">
              <span class="project-org-block">{project.org}</span>
              <div class="project-role-row">
                <span class="project-role-chip">{project.role}</span>
                <span class="pill">{project.period}</span>
              </div>
            </div>
            <div class="project-head project-head-column">
              <h3>{project.title}</h3>
              <span class="tag">{project.tag}</span>
            </div>
            <p>{project.desc}</p>
            {project.links && project.links.length > 0 && (
              <div class="button-row" style="margin-top: 1rem;">
                {project.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="button secondary" style="padding: 0.6rem 1.1rem; font-size: 0.85rem;">
                    {link.text}
                  </a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
