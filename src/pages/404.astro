---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Yi-Chen Sun">
  <section class="hero compact">
    <div class="container narrow">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lede">The page you are looking for does not exist or may have moved.</p>
      <div class="hero-actions">
        <a class="button primary" href="/">Back to Home</a>
        <a class="button secondary" href="/cv/">View CV</a>
      </div>
    </div>
  </section>
</BaseLayout>
