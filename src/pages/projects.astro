---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { projectCards } from '../data/site';
---
<BaseLayout path="/projects" title="Projects">
  <section class="page-hero">
    <div class="container narrow">
      <SectionHeading eyebrow="Project Portfolio" title="Projects" intro="Projects are organized around your CV content, with institution or organization shown in a strong blue block and role shown in a softer block for clearer visual hierarchy." />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="feature-grid two-cols">
        {projectCards.map((project) => (
          <article class="project-card project-card-rich featured">
            <div class="project-meta-stack">
              <span class="project-org-block">{project.org}</span>
              <div class="project-role-row">
                <span class="project-role-chip">{project.role}</span>
                <span class="pill">{project.period}</span>
              </div>
            </div>
            <div class="project-head project-head-column">
              <h3>{project.title}</h3>
              <span class="tag">{project.tag}</span>
            </div>
            <p>{project.desc}</p>
            <ul class="bullet-list compact project-bullets">
              {project.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
