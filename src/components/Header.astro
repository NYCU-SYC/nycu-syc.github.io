---
import { navItems, siteMeta } from '../data/site';
const { path = '/' } = Astro.props;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-title">{siteMeta.title}</span>
      <span class="brand-subtitle">{siteMeta.subtitle}</span>
    </a>
    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href} class:list={{ active: path === item.href }}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
