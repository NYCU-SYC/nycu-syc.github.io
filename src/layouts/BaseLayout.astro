---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteMeta } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const { title, description = siteMeta.description, path = '/' } = Astro.props;
const pageTitle = title ? `${title} | ${siteMeta.title}` : `${siteMeta.title} | Academic Website`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header path={path} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
